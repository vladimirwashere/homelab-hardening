# Hermes Agent environment template.
# Goes on system at: /root/.hermes/.env  (mode 600)
# Used in: Phase 12.
#
# NEVER commit this file with real keys. Replace [REPLACE_ME_*]
# markers locally and chmod 600 before Hermes reads it.

# --- Provider keys ---------------------------------------------
# OpenRouter is the primary provider in the default config.
OPENROUTER_API_KEY=[REPLACE_ME_OPENROUTER_KEY]

# Optional direct escape-hatch keys. Leave commented unless used.
# OPENAI_API_KEY=[REPLACE_ME_OPENAI_KEY]
# ANTHROPIC_API_KEY=[REPLACE_ME_ANTHROPIC_KEY]
# DEEPSEEK_API_KEY=[REPLACE_ME_DEEPSEEK_KEY]
# GEMINI_API_KEY=[REPLACE_ME_GEMINI_KEY]

# Ollama sidecar (Step 12.9) ignores this value but Hermes
# requires *something* non-empty when provider: custom is used.
# OPENAI_API_KEY=ollama-ignored

# --- Hermes hardening flags ------------------------------------
# Do NOT enable YOLO mode on this host. Trading-adjacent workload.
HERMES_YOLO_MODE=false

# Restrict file writes to a single working tree.
HERMES_WRITE_SAFE_ROOT=/root/work

# Mask secrets in logs.
HERMES_REDACT_SECRETS=true

# Long-running tool calls (inference, data fetches) need headroom.
HERMES_API_TIMEOUT=1800

# --- Gateway allowlists (only if a messaging channel is on) ----
# GATEWAY_ALLOW_ALL_USERS=false
# GATEWAY_ALLOWED_USERS=[REPLACE_ME_TELEGRAM_USER_ID]
# TELEGRAM_ALLOWED_USERS=[REPLACE_ME_TELEGRAM_USER_ID]
# TELEGRAM_BOT_TOKEN=[REPLACE_ME_TELEGRAM_BOT_TOKEN]
